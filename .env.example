# =====================
# Admin backend env vars (example/template)
# =====================
# Mongo / DB
MONGO_URI=

# Server/CORS
NODE_ENV=development
CLIENT_URL=http://localhost:8081

# JWT auth (used by adminAuthMiddleware / controllers)
JWT_SECRET=
JWT_EXPIRES_IN=
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=

# Cloudinary (profile/product image upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ImageKit (if admin uses product image handling)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Razorpay (if admin handles payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email/OTP (if admin uses OTP/email)
EMAIL_FROM=
RESEND_API_KEY=

