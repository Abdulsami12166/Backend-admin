# =====================
# Admin backend environment variables
# =====================
# NOTE:
# - Do NOT commit secrets to GitHub.
# - Keep this file locally or add it to .gitignore.
# - For Render/production, set Environment Variables instead.

# Mongo / DB
MONGO_URI=

# Server/CORS
NODE_ENV=production
CLIENT_URL=http://localhost:8081

# Admin JWT
ADMIN_JWT_SECRET=

# Optional JWT refresh (only if your admin routes use it)
JWT_SECRET=
JWT_EXPIRES_IN=
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=

# Cloudinary (if used)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ImageKit (if used)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Razorpay (if used)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email/OTP (if used)
EMAIL_FROM=
RESEND_API_KEY=

